# ==========================================
# ERP Indusvit Backend — Variables de Entorno
# Copiar a .env y ajustar valores
# ==========================================

# App
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change_me_in_production_use_openssl_rand_base64_64
JWT_EXPIRES_IN=8h

# CORS — origen del frontend React
CORS_ORIGIN=http://localhost:5173

# Base de datos PostgreSQL
# --- Desarrollo local (Docker):
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/indusvit_erp
DIRECT_URL=postgresql://postgres:devpassword@localhost:5432/indusvit_erp
# --- Vercel + Supabase (pruebas en la nube):
# DATABASE_URL  → Transaction pooler (puerto 6543) — para Vercel serverless
# DIRECT_URL    → Conexión directa (puerto 5432)   — para prisma migrate deploy
# Ambas URLs están en: Supabase dashboard → Project Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# DIAN — Ambiente de Habilitación
DIAN_WSDL_URL=https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc?wsdl
DIAN_CERT_PATH=./certs/indusvit.p12
DIAN_CERT_PASSWORD=
DIAN_NIT=900000001
DIAN_NIT_DIAN=800197268
